{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Build & Deploy EXE",
      "type": "node-terminal",
      "request": "launch",
      "command": "uv run python build.py --clean --deploy",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Build Docker Image",
      "type": "node-terminal",
      "request": "launch",
      "command": "docker build -t as-help:local .",
      "cwd": "${workspaceFolder}"
    }
  ]
}
